# FastAPI Configuration
APP_NAME=Aegis Twin
APP_VERSION=1.0.0
DEBUG=True

# Neo4j Configuration
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# Source Control Tokens (optional)
GITHUB_TOKEN=
GITLAB_TOKEN=
BITBUCKET_TOKEN=

# LLM Configuration (Phase 2)
ANTHROPIC_API_KEY=

# API Configuration
MAX_DIFF_SIZE=500000
SIMULATION_TIMEOUT=30
INGESTION_TIMEOUT=300
